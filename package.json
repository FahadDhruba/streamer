{
  "name": "live-streaming-server",
  "version": "1.0.0",
  "description": "Production-ready Node.js live streaming server: RTMP ingest, FFmpeg ABR HLS transcoding, Cloudflare R2 storage, and post-stream VOD recording.",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "addkey": "node scripts/addkey.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.1",
    "chokidar": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "node-media-server": "^2.7.4",
    "p-limit": "^6.1.0"
  },
  "license": "MIT"
}

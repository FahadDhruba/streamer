# ============================================================
# Live Streaming Server - Environment Configuration
# Copy this file to `.env` and fill in real values.
# ============================================================

# ---------- Server Ports ----------
RTMP_PORT=1935
EXPRESS_PORT=3000

# ---------- Cloudflare R2 (S3-compatible) ----------
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=33f3135e020163d5e1de082267efccdc
R2_ACCESS_KEY_ID=2188d4163bd9d9813832db6287d91c3a
R2_SECRET_ACCESS_KEY=39f9b5a00cb835e38d308fd2363e77735ce9a287eccc89221c3a265fb3918e0b
R2_BUCKET_NAME=streaming

# Public base URL for the bucket (R2.dev URL or custom domain).
# Must NOT end with a trailing slash. Used to build playable HLS URLs.
# Example: https://pub-xxxxxxxxx.r2.dev   or   https://cdn.example.com
R2_PUBLIC_URL=https://pub-0f686843b40f4f468be98dee12fff3aa.r2.dev

# ---------- FFmpeg ----------
# Absolute path to the ffmpeg binary on this host.
# Linux:   /usr/bin/ffmpeg
# macOS:   /opt/homebrew/bin/ffmpeg
# Windows: C:\\ffmpeg\\bin\\ffmpeg.exe
# FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_PATH=C:\\ffmpeg\\bin\\ffmpeg.exe

# ---------- Local Temp Storage ----------
# Directory for live HLS segments before they are uploaded to R2.
TMP_DIR=./tmp/live

# ---------- Upload Tuning ----------
# Maximum number of parallel R2 uploads across the whole server.
MAX_UPLOAD_CONCURRENCY=5

# ---------- Stream-key Authorization Mode ----------
# true  (default) → "open mode": ANY stream key works. The first time a key
#                   is used to broadcast, it is auto-registered in
#                   streamkeys.json. Great for solo / dev / trusted use.
# false           → "strict mode": only keys explicitly added via
#                   `npm run addkey` or POST /api/admin/streamkey are
#                   allowed. Recommended for public-facing production.
OPEN_MODE=true

# ---------- Optional: Admin API protection ----------
# If set, POST /api/admin/* and DELETE /api/admin/* require:
#   header  X-Admin-Token: <ADMIN_TOKEN>
# Leave empty to disable (NOT recommended for production).
ADMIN_TOKEN=
